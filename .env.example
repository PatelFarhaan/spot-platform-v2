# AWS Configuration
AWS_PROFILE=default
AWS_REGION=us-east-1
ECR_HOST=xxxxxxxxxxxx.dkr.ecr.us-east-1.amazonaws.com

# Slack Notifications
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# Git Integration
GIT_API_TOKEN=your-git-api-token
GIT_USERNAME=your-git-username
GIT_PASSWORD=your-git-password

# Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_PASSWORD=changeme
VAULT_DEFAULT_PASSWORD=changeme

# Jenkins Configuration
JENKINS_USERNAME=admin
JENKINS_PASSWORD=changeme

# Auto-Scaler Configuration
PROMETHEUS_URL=http://your-prometheus-host:9090
